APP_NAME=Facial Recognition TP1
MODEL_NAME=face_detection.pth
SIMILARITY_METRIC=cosine
SIMILARITY_THRESHOLD=0.55
EMBEDDINGS_PATH=data/embeddings.json
DATA_PATH=data
OUTPUT_PATH=output
CORS_ORIGINS="http://localhost:8080,http://frontend:8080"
MODEL_PATH=models
MAX_WORKERS=2
FACE_SIZE=112
# Must match your face embedding model Example: (InsightFace ArcFace is usually 512).
EMBEDDING_DIM=512

# PostgreSQL / pgvector (future integration)
USE_PGVECTOR=true
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=faces
POSTGRES_USER=faces_user
POSTGRES_PASSWORD=faces_pass
